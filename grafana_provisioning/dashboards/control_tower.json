    "panel-2": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "PostgreSQL"
                    },
                    "group": "PostgreSQL",
                    "kind": "DataQuery",
                    "spec": {
                      "dataset": "postgres",
                      "editorMode": "code",
                      "format": "table",
                      "rawQuery": true,
                      "rawSql": "SELECT\r\n  event_at AS time,\r\n  level AS \"Niveau\",\r\n  layer AS \"Couche\",\r\n  dag_id AS \"Nom du DAG\",\r\n  task_id AS \"Tâche\",\r\n  message AS \"Message de Log\"\r\nFROM logs.airflow_events\r\nWHERE $__timeFilter(event_at)\r\nORDER BY event_at DESC\r\nLIMIT 100;",
                      "sql": {
                        "columns": [
                          {
                            "parameters": [],
                            "type": "function"
                          }
                        ],
                        "groupBy": [
                          {
                            "property": {
                              "type": "string"
                            },
                            "type": "groupBy"
                          }
                        ],
                        "limit": 50
                      }
                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "Flux de logs en temps réel des pipelines d'ingestion et des transformations dbt.",
        "id": 2,
        "links": [],
        "title": "Logs d'Orchestration & DataOps (Airflow)",
        "vizConfig": {
          "group": "table",
          "kind": "VizConfig",
          "spec": {
            "fieldConfig": {
              "defaults": {
                "custom": {
