                    "type": "value"
                  }
                ],
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "dark-green",
                      "value": 0
                    }
                  ]
                }
              },
              "overrides": [
                {
                  "matcher": {
                    "id": "byName",
                    "options": "Niveau",
                    "scope": "series"
                  },
                  "properties": [
                    {
                      "id": "custom.cellOptions",
                      "value": {
                        "applyToRow": false,
                        "mode": "basic",
                        "type": "color-background"
                      }
