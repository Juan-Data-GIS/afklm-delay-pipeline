# =============================================================================
# DOCKER INFRASTRUCTURE & NOMMAGE
# =============================================================================
COMPOSE_PROJECT_NAME=afklm-formation

# Ports exposés pour la soutenance (Évite les conflits avec VetEternity)
AIRFLOW_WEB_PORT=8081
STREAMLIT_PORT=8501
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
POSTGRES_EXPORTER_PORT=9187

# Ports internes de la stack
FASTAPI_PORT=8000
AIRFLOW_POSTGRES_PORT=5450
LOCAL_POSTGRES_PORT=5432

# =============================================================================
# ENVIRONNEMENT GLOBAL
# =============================================================================
ENV=prod
# Target dbt (profiles.yml) — valeurs : local | dev | prod
# Doit rester cohérent avec ENV_TARGET ci-dessous.
DBT_TARGET=prod

# =============================================================================
# SELECTEUR RUNTIME (api_app.py, ml_run.py, monitoring_utils.py)
# =============================================================================
# Valeurs possibles : "local" (Postgres Docker interne) ou "prod" (Supabase Cloud).
# Doit rester cohérent avec DBT_TARGET ci-dessus.
# Sans cette variable, api_app.py / ml_run.py fallbackent sur "local" et
# se connectent à afklm-formation-postgres-local (data_hub) au lieu de Supabase.
ENV_TARGET=prod

# Active/désactive l'écriture des logs Airflow dans logs.airflow_events
# Utile pour couper le bruit lors d'un run rapide en local. Défaut : 1 (actif).
AIRFLOW_LOG_TO_DB=1

# =============================================================================
# LAYER 1 : INGESTION (API AIR FRANCE KLM)
# =============================================================================
AF_API_URL=https://api.airfranceklm.com/opendata

# Pool de clés pour la gestion du Failover - Remplacer par vos clés de l'OpenData AFKLM
AF_CLIENT_ID_1=votre_api_key_1_ici
AF_CLIENT_ID_2=votre_api_key_2_ici
AF_CLIENT_ID_3=votre_api_key_3_ici
AF_CLIENT_ID_4=votre_api_key_4_ici
AF_CLIENT_ID_5=votre_api_key_5_ici

SOURCES__AFKLM__API_KEY=votre_api_key_1_ici

# =============================================================================
# LAYER 2 : STORAGE & TRANSFORMATION (SUPABASE POSTGRES)
# =============================================================================
# Variables maîtresse dbt - Remplacer par l'hôte de votre base Supabase
AFKLM_DB_HOST=votre-projet-id.pooler.supabase.com
AFKLM_DB_PORT=5432
AFKLM_DB_NAME=postgres
AFKLM_DB_USER=postgres.votre-user-id
AFKLM_DB_PASSWORD=your-password-here
AFKLM_DB_SSLMODE=require

# Références de compatibilité pour l'infra Python classique (psycopg2 / dlt)
DB_HOST=${AFKLM_DB_HOST}
DB_PORT=${AFKLM_DB_PORT}
DB_NAME=${AFKLM_DB_NAME}
DB_USER=${AFKLM_DB_USER}
DB_PASSWORD=${AFKLM_DB_PASSWORD}
DB_SCHEMA=public

# RESOLUTION COMPATIBILITE DLT -> SUPABASE
DESTINATION__POSTGRES__CREDENTIALS="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=require"

# Configuration d'exécution de DLT / dbt
SOURCES__AFKLM__INCREMENTAL=True
DBT_THREADS=4

# =============================================================================
# LAYER 3 : SERVING & MACHINE LEARNING (FASTAPI)
# =============================================================================
# Artifacts de modèles ML (URLs signées Supabase Storage, à régénérer périodiquement si expirées)
MODEL_MEANS_URL=https://<votre-projet-id>.supabase.co/storage/v1/object/sign/ml_models/means_<timestamp>.pkl?token=<votre-signed-url-token>
MODEL_SCALER_URL=https://<votre-projet-id>.supabase.co/storage/v1/object/sign/ml_models/scaler_<timestamp>.pkl?token=<votre-signed-url-token>
MODEL_XGB_URL=https://<votre-projet-id>.supabase.co/storage/v1/object/sign/ml_models/xgb_<timestamp>.pkl?token=<votre-signed-url-token>