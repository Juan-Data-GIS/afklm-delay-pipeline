      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(node_filesystem_free_bytes) / 1024 / 1024 / 1024",
          "legendFormat": "Espace Libre Total (Go)",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom", "showLegend": true }
