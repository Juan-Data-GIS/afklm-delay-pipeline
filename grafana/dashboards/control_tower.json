      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 8,
      "title": "Usage RAM Critique - Base Postgres Analytics",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "process_resident_memory_bytes{job=\"postgres-analytics\"}",
          "legendFormat": "RAM Postgres Local",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "max": 268435456,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 67108864 },
              { "color": "red", "value": 134217728 }
            ]
          }
        }
      },
      "options": { "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "textMode": "auto" }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "id": 15,
      "title": "Usage RAM Actuel - FastAPI Application",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "process_resident_memory_bytes{job=\"fastapi-service\"}",
          "legendFormat": "RAM FastAPI",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "max": 536870912,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 268435456 },
              { "color": "red", "value": 402653184 }
            ]
          }
        }
      },
      "options": { "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "textMode": "auto" }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
      "id": 16,
      "title": "Volume d'Erreurs Serveur API (HTTP 5xx)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(increase(http_requests_total{status=~\"5..\"}[5m])) or on() vector(0)",
          "legendFormat": "Erreurs HTTP 5xx (5m)",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "textMode": "value" }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 5 },
      "id": 1,
      "title": "Latence Moyenne API (Performance)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(http_request_duration_seconds_sum[5m])) by (handler) / sum(rate(http_request_duration_seconds_count[5m])) by (handler)",
          "legendFormat": "{{handler}} (Latence)",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "title": "Bruit de Fond API (Appels Reseau / sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total[1m])) by (status, handler)",
          "legendFormat": "{{handler}} - Status {{status}}",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "right", "showLegend": true }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 11 },
      "id": 7,
      "title": "Charge Memoire de l'Infrastructure (Evolution)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "process_resident_memory_bytes{job=~\".*\"}",
          "legendFormat": "Usage RAM - {{job}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "calcs": ["last"], "displayMode": "table", "placement": "right", "showLegend": true } }
    }
