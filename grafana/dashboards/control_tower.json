    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 5 },
      "id": 22,
      "title": "[Local] Serveur : Charge CPU Globale (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "Charge CPU Globale %",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 5 },
      "id": 23,
      "title": "[Local] Serveur : Activité Multi-Cœurs (Détail)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum by (cpu) (rate(node_cpu_seconds_total{mode!=\"idle\"}[5m])) * 100",
          "legendFormat": "Cœur {{cpu}}",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "right", "showLegend": true }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 11 },
      "id": 6,
      "title": "[Docker] Application : Bruit de Fond API (Requêtes / sec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total[1m])) by (status, handler) or on() vector(0)",
          "legendFormat": "{{handler}} - Status {{status}}",
          "range": true,
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 11 },
      "id": 16,
      "title": "[Docker] Application : Volume Erreurs (HTTP 5xx) & Erreurs DB",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(increase(http_requests_total{status=~\"5..\"}[5m])) or on() vector(0)",
          "legendFormat": "Erreurs HTTP 5xx",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "value" }
    },
    {
      "collapsed": false,
