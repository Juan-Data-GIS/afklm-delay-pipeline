      "id": 40,
      "title": "[Docker] Tour de Contrôle : État de Disponibilité des Moteurs et Services (AFKLM)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "up",
          "legendFormat": "__auto",
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true
            },
            "indexByName": {},
            "renameByName": {
              "job": "Composant Réseau Docker",
              "Value": "Statut"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "showTypeIcons": false
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "✔ SERVICE EN LIGNE (OK)", "color": "green" },
                "0": { "text": "✖ INDISPONIBLE (ALERTE)", "color": "red" }
              }
            },
            {
              "type": "regex",
              "options": {
                "pattern": "postgres-analytics",
                "result": { "text": "PostgreSQL Analytics" }
              }
            },
            {
              "type": "regex",
              "options": {
                "pattern": "fastapi-service",
                "result": { "text": "FastAPI Application" }
              }
            },
            {
              "type": "regex",
              "options": {
                "pattern": "prometheus",
                "result": { "text": "Prometheus Engine" }
              }
            },
            {
              "type": "regex",
              "options": {
                "pattern": "node-exporter",
                "result": { "text": "Node Exporter (Hôte)" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Statut"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              }
            ]
          }
        ]
      }
    }
