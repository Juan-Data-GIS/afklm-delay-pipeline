    {
      "collapsed": false,
      "gridPos": { "h": 5, "w": 5, "x": 0, "y": 0 },
      "id": 8,
      "title": "[Docker] Usage RAM - Base Postgres Analytics",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "max(process_resident_memory_bytes{job=\"postgres-analytics\"})",
          "legendFormat": "RAM Postgres Local",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "max": 268435456,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 67108864 },
              { "color": "red", "value": 134217728 }
            ]
          }
        }
      },
      "options": { "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "textMode": "auto" }
    },
    {
